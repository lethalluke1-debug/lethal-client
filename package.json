{
  "name": "lethal-client",
  "version": "0.1.26",
  "description": "A real Fabric-based Minecraft launcher: Microsoft login, Modrinth mod downloads, Fabric install, and game launch.",
  "author": "Lethal Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lethalclient.app",
    "productName": "Lethal Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "renderer/**/*",
      "src/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "lethalluke1-debug",
      "repo": "lethal-client"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "artifactName": "Lethal-Client-Setup.exe"
    }
  }
}
